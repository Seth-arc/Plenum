{
  "name": "plenum-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Plenum — launch / product marketing site with embedded Remotion brand film.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "video:studio": "remotion studio src/remotion/index.ts",
    "video:render": "remotion render src/remotion/index.ts PlenumBrandFilm out/plenum-brand-film.mp4",
    "video:still": "remotion still src/remotion/index.ts PlenumBrandFilm out/plenum-poster.png --frame=210"
  },
  "dependencies": {
    "@remotion/player": "4.0.290",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.290"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.290",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "typescript": "5.6.3",
    "vite": "5.4.21"
  }
}
